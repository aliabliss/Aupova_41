<Page x:Class="Aupova_41.AuthPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Aupova_41"
      mc:Ignorable="d" 
      d:DesignHeight="900" d:DesignWidth="1500"
      Title="AuthPage" FontFamily="Comic Sans MS" Background="White">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="59*"/>
            <ColumnDefinition Width="91*"/>
        </Grid.ColumnDefinitions>
        <TextBlock Text="Логин" Grid.Column="0" VerticalAlignment="Top" HorizontalAlignment="Left" Margin="458,138,0,0" FontSize="30" Height="46" Width="98"/>
        <TextBox x:Name="LoginTB" Grid.Row="0" Grid.Column="1" Margin="44,139,496,91" FontSize="30" VerticalContentAlignment="Center"/>
        <TextBlock Text="Пароль" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="458,0,0,0" FontSize="30" Height="41" Width="122"/>
        <TextBox x:Name="PassTB" Grid.Column="1" Margin="44,115,496,115" FontSize="30" VerticalContentAlignment="Center" Grid.Row="1"/>
        <Button x:Name="BtnGuest" Content="Войти как гость" Grid.Row="2" Grid.Column="0"  Click="BtnGuest_Click" Margin="145,139,140,-129" Width="NaN"/>
        <Button x:Name="BtnLogin" Content="Войти"  Grid.Row="2" Grid.Column="1" Click="LoginBtn_Click" Margin="145,139,145,-129" Width="300"/>
        <StackPanel Orientation="Horizontal" Grid.Row="2" Grid.Column="1" Margin="0,0,561,0">
            <TextBlock Name="captchaOneWord" FontSize="22" Margin="30,0,0,0"></TextBlock>
            <TextBlock Name="captchaTwoWord" FontSize="22" TextDecorations="Strikethrough" Margin="0,5,0,0"></TextBlock>
            <TextBlock Name="captchaThreeWord" FontSize="22" TextDecorations="Strikethrough"></TextBlock>
            <TextBlock Name="captchaFourWord" FontSize="22" TextDecorations="Strikethrough" Margin="0,10,0,0"></TextBlock>
        </StackPanel>
        <StackPanel x:Name="CaptchaPanel" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,-15" Visibility="Collapsed" Grid.Column="1" Grid.Row="2" Width="422">
            <TextBlock Text="Введите капчу:" FontSize="22"  VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBlock x:Name="CaptchaText" FontSize="22" FontWeight="Bold" Margin="5" 
               Foreground="Black" TextDecorations="Strikethrough" VerticalAlignment="Center"/>
            <TextBox x:Name="CaptchaInput" Width="153" Margin="5" Height="25" VerticalAlignment="Center"/>

        </StackPanel>
    </Grid>

</Page>
