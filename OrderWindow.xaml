<Window x:Class="Aupova_41.OrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Aupova_41"
         d:DesignHeight="900" d:DesignWidth="1500"
  Title="OrderWindow" FontFamily="Comic Sans MS">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="60"/>
            <RowDefinition Height="60"/>
            <RowDefinition Height="60"/>
            <RowDefinition Height="500"/>
            <RowDefinition Height="60"/>
            <RowDefinition Height="60*"/>
            <RowDefinition Height="0"/>

        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="400"/>
            <ColumnDefinition Width="50*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Text="Дата формирования заказа" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="30" Height="46" Width="382"/>
        <TextBlock Text="Дата доставки заказа" VerticalAlignment="Top" HorizontalAlignment="Left" FontSize="30" Height="46" Width="360" Grid.Row="1" Margin="9,4,0,0"/>
        <TextBlock Text="ФИО клиента" VerticalAlignment="Top" HorizontalAlignment="Left" FontSize="30" Height="46" Width="360" Grid.Row="2" Margin="10,10,0,0"/>
        <TextBlock Name="FIOTB" TextAlignment="Left" FontSize="20" Margin="0,8,0,9" Grid.Column="1" Grid.Row="2" ></TextBlock>
        <TextBlock Text="Номер заказа" VerticalAlignment="Center" HorizontalAlignment="Left" FontSize="30" Height="46" Width="360" Grid.Row="3" Margin="9,0,0,0"/>
        <TextBlock Name="NUMBERTB" TextAlignment="Left" FontSize="20" Margin="0,7,0,10" Grid.Column="1" Grid.Row="3" ></TextBlock>
        <TextBlock Text="Пункт выдачи" VerticalAlignment="Center" HorizontalAlignment="Left" FontSize="30" Height="46" Width="360" Grid.Row="5" Margin="10,0,0,0"/>
        <ComboBox Name="ComboPickUpPoint" SelectionChanged="ComboPickUpPoint_SelectionChanged" Grid.Column="1" Grid.Row="5" ></ComboBox>
        <DatePicker Grid.Row="0" Grid.Column="1" Height="50" FontSize="25"  x:Name="DateOrder"
        SelectedDate="{Binding SelectedDate}"
        DisplayDateStart="2000-01-01" 
        DisplayDateEnd="2100-12-31" Margin="0,5,0,5"/>
        <DatePicker Grid.Row="1" Grid.Column="1" Height="50" FontSize="25"  x:Name="DateDelivery"
       SelectedDate="{Binding SelectedDate}"
       DisplayDateStart="2000-01-01" 
       DisplayDateEnd="2100-12-31"  Margin="0,5,0,5"/>
        
        <Button Name="BtnSave" Content="Сохранить"  Grid.Row="6" Grid.Column="1" Click="SaveBtn_Click" Width="300"></Button>


        <ListView Name="ShoeListView" SelectionChanged="ShoeListView_SelectionChanged" Grid.ColumnSpan="2"  Grid.Row="4">
            <ListView.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Добавить к заказу" Click="MenuItem_Click"></MenuItem>
                </ContextMenu>
            </ListView.ContextMenu>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"></ColumnDefinition>
                            <ColumnDefinition Width="750"></ColumnDefinition>
                            <ColumnDefinition Width="*"></ColumnDefinition>

                        </Grid.ColumnDefinitions>

                        <Image Width="200" Grid.Column="1" Grid.RowSpan="400" Stretch="UniformToFill" HorizontalAlignment="Center">
                            <Image.Source>
                                <Binding Path="ProductPhotoPath">
                                    <Binding.TargetNullValue>
                                        <ImageSource>
                                            /res/picture.png
                                        </ImageSource>
                                    </Binding.TargetNullValue>
                                </Binding>
                            </Image.Source>
                        </Image>
                        <TextBlock Text="{Binding ProductName}" Grid.Column="1" Grid.Row="0" HorizontalAlignment="Left" FontSize="20" TextWrapping="Wrap"></TextBlock>
                        <TextBlock Text="{Binding ProductDescription}"  Grid.Column="1" Grid.Row="1" HorizontalAlignment="Left" FontSize="20"></TextBlock>
                        <TextBlock Text="{Binding ProductManufacturer}" Grid.Column="1" Grid.Row="2" HorizontalAlignment="Left" FontSize="20"></TextBlock>
                        <TextBlock Text="{Binding ProductCost, StringFormat={}{0:0} рублей}" Grid.Column="1" Grid.Row="3" HorizontalAlignment="Left" FontSize="16"></TextBlock>
                        <TextBlock Text="{Binding ProductDiscountAmount, StringFormat={}{0} % }" Grid.Column="2" Grid.Row="1" HorizontalAlignment="Right" FontSize="25"></TextBlock>
                        <TextBlock Text="Скидка" Grid.Column="2" Grid.Row="0" HorizontalAlignment="Right" FontSize="20"></TextBlock>
                        <TextBlock Text="{Binding ProductQuantityInStock, StringFormat='Количество в заказе: {0} шт.'}" 
                       Grid.Column="1" Grid.Row="4" HorizontalAlignment="Left" FontSize="16" 
                       Foreground="Red" FontWeight="SemiBold"></TextBlock>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Window>
