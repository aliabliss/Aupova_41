<Window x:Class="Aupova_41.OrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Aupova_41"
        Height="900" Width="1500"
  Title="OrderWindow" FontFamily="Comic Sans MS">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="60"/>
            <RowDefinition Height="60"/>
            <RowDefinition Height="60"/>
            <RowDefinition Height="500"/>
            <RowDefinition Height="60"/>
            <RowDefinition Height="60*"/>
            <RowDefinition Height="0"/>

        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="443"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <TextBlock Text="Дата формирования заказа" VerticalAlignment="Center" HorizontalAlignment="Left" FontSize="30" Height="46" Width="404" Margin="10,0,0,0"/>
        <TextBlock Text="Дата доставки заказа" VerticalAlignment="Top" HorizontalAlignment="Left" FontSize="30" Height="46" Width="360" Grid.Row="1" Margin="9,4,0,0"/>
        <TextBlock Text="ФИО клиента" VerticalAlignment="Top" HorizontalAlignment="Left" FontSize="30" Height="46" Width="360" Grid.Row="2" Margin="10,10,0,0"/>
        <TextBlock Name="FIOTB" TextAlignment="Left" FontSize="20" Margin="0,8,0,9" Grid.Column="1" Grid.Row="2" ></TextBlock>
        <TextBlock Text="Номер заказа" VerticalAlignment="Center" HorizontalAlignment="Left" FontSize="30" Height="46" Width="360" Grid.Row="3" Margin="9,0,0,0"/>
        <TextBlock Name="NUMBERTB" TextAlignment="Left" FontSize="20" Margin="0,7,0,10" Grid.Column="1" Grid.Row="3" ></TextBlock>
        <TextBlock Text="Пункт выдачи" VerticalAlignment="Center" HorizontalAlignment="Left" FontSize="30" Height="46" Width="360" Grid.Row="5" Margin="10,0,0,0"/>
        <!--<ComboBox Name="ComboPickUpPoint" SelectionChanged="ComboPickUpPoint_SelectionChanged" Grid.Column="1" Grid.Row="5" ></ComboBox>-->
        <!-- Дата заказа (автоматическая, read-only) -->
        <ComboBox Name="ComboPickUpPoint" 
  Grid.Row="5"
  DisplayMemberPath="FullAddress"
  Grid.ColumnSpan="2" Margin="225,0,0,0"
  SelectionChanged="ComboPickUpPoint_SelectionChanged" Height="40"/>

        <DatePicker Grid.Row="0" Grid.Column="1" 
   Height="50" 
   FontSize="25"  
   x:Name="DateOrder"
   DisplayDateStart="2000-01-01" 
   DisplayDateEnd="2100-12-31" 
   Margin="0,5,0,5" IsEnabled="False"/>

        <DatePicker Grid.Row="1" Grid.Column="1" 
   Height="50" 
   FontSize="25"  
   x:Name="DateDelivery"
   DisplayDateStart="2000-01-01" 
   DisplayDateEnd="2100-12-31"  
   Margin="0,5,0,5"/>


        <!--<Button Name="BtnSave" Content="Сохранить"  Grid.Row="6" Grid.Column="1" Click="SaveBtn_Click" Width="300"></Button>-->


        <!--<ListView Name="ShoeListView" SelectionChanged="ShoeListView_SelectionChanged" Grid.ColumnSpan="2"  Grid.Row="4">-->
        <!--<ListView.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Добавить к заказу" Click="MenuItem_Click"></MenuItem>
                </ContextMenu>
            </ListView.ContextMenu>-->
        <ListView Name="ShoeListView"
                      
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled" Grid.Row="4" Grid.ColumnSpan="2">

            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Height="150" Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="180"/>
                        </Grid.ColumnDefinitions>

                        <!-- Изображение товара -->

                        <Image  Width="140" Height="140" Grid.Column="0" 
                       Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Image.Source>
                                <Binding Path="ProductPhotoPath">
                                    <Binding.TargetNullValue>
                                        <ImageSource>
                                            /res/picture.png
                                        </ImageSource>
                                    </Binding.TargetNullValue>
                                </Binding>
                            </Image.Source>
                        </Image>

                        <!-- Информация о товаре -->
                        <StackPanel Grid.Column="1" Margin="10,0">
                            <TextBlock Text="{Binding ProductName}" 
                               FontSize="16" 
                               Margin="0,0,0,5"/>

                            <TextBlock Text="{Binding ProductDescription}" 
                               FontSize="14"
                               
                               Margin="0,0,0,5"
                               MaxHeight="40"/>

                            <TextBlock Text="{Binding ProductManufacturer}" 
                               FontSize="14" 
                               Margin="0,0,0,5"/>

                            <TextBlock Text="{Binding ProductCost, StringFormat={}{0:0} рублей}" 
                               FontSize="16" 
                              />

                            <!-- Панель управления количеством -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,10,0,0">
                                <TextBlock Text="Количество: " FontSize="14" VerticalAlignment="Center"/>

                                <!-- Кнопка минус -->
                                <Button Name="BtnMinus" Content="-" Width="30" Height="30" Margin="5,0" 
                                Click="BtnMinus_Click" Tag="{Binding}">


                                </Button>

                                <!-- Количество -->
                                <TextBlock Text="{Binding ProductQuantityInStock}" 
                                   FontSize="16" FontWeight="Bold"
                                   Width="30" TextAlignment="Center" 
                                   VerticalAlignment="Center" Margin="5,0"/>

                                <!-- Кнопка плюс -->
                                <Button Name="BtnPlus" Content="+" Width="30" Height="30" Margin="5,0"
                                Click="BtnPlus_Click" Tag="{Binding}"></Button>


                                <!-- Кнопка удаления -->
                                <Button Name="BtnDelete" Content="Удалить" Width="100" FontSize="14" Height="30" Margin="10,0"
                                Click="BtnDelete_Click" Tag="{Binding}">


                                </Button>
                            </StackPanel>
                        </StackPanel>

                        <!-- Скидка и стоимость -->
                        <StackPanel Grid.Column="2" Margin="0,0,10,0" VerticalAlignment="Top">
                            <!-- Скидка -->
                            <Border CornerRadius="5" Padding="8,5"
                            HorizontalAlignment="Right" Margin="0,0,0,10">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Скидка" FontSize="14" Margin="0,0,5,0"/>
                                    <TextBlock Text="{Binding ProductDiscountAmount, StringFormat={}{0}%}" 
                                       FontSize="16" />
                                </StackPanel>
                            </Border>


                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>


        </ListView>


       

        <!-- Кнопка сохранения и итоговая сумма -->
        <Grid Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="2"
              Margin="10,10,10,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Итоговая сумма -->

            <StackPanel Orientation="Horizontal" 
                            HorizontalAlignment="Left">
                <TextBlock Text="Итого к оплате:" 
                               FontSize="30" Width="236" 
                               
                               />
                <TextBlock Name="DiscountTextBlock" FontSize="14"
           Visibility="Collapsed" Margin="0,0,0,5"/>
                <TextBlock x:Name="TotalAmountText" 
                               Text="0 рублей" 
                               FontSize="30" Width="1030" 
                               
                               />
            </StackPanel>


            <!-- Кнопка сохранения -->
            <Button Grid.Column="1"
                    Name="BtnSave" 
                    Content="Сохранить заказ" 
                    Width="200" 
                    Height="50"
                    
                    Click="SaveBtn_Click"
                    VerticalAlignment="Center">

            </Button>
        </Grid>
    </Grid>
</Window>
