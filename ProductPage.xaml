<Page x:Class="Aupova_41.ProductPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Aupova_41"
      mc:Ignorable="d" 
      d:DesignHeight="900" d:DesignWidth="1500"
      Title="ProductPage" FontFamily="Comic Sans MS">

    <Grid Background="#FFFFCC99" Margin="0,10,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="50"></RowDefinition>
            <RowDefinition Height="100"></RowDefinition>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <TextBlock Text="Вы авторизованы как " TextAlignment="Left" FontSize="20" Margin="10,0,1251,25"></TextBlock>
        <TextBlock Text="Роль: " TextAlignment="Left" FontSize="20" Margin="10,22,1386,0"/>
        <TextBlock Name="FIOTB" TextAlignment="Left" FontSize="20" Margin="223,0,10,17" ></TextBlock>
        <TextBlock Name="RoleTB" TextAlignment="Left" FontSize="20" Margin="67,21,1168,0" ></TextBlock>
        <WrapPanel Orientation="Vertical" HorizontalAlignment="Left" Width="267"  Grid.Row="1" Margin="248,15,0,14">
            <StackPanel RenderTransformOrigin="0.5,0.5">
                <StackPanel.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform/>
                        <SkewTransform/>
                        <RotateTransform Angle="-0.14"/>
                        <TranslateTransform/>
                    </TransformGroup>
                </StackPanel.RenderTransform>
                <TextBlock Text="Поиск по наименованию" TextAlignment="Left"
       Width="300" FontSize="20"></TextBlock>
                <TextBox x:Name="TBoxSearch" TextChanged="TBoxSearch_TextChanged"
       Width="262" FontSize="15"></TextBox>

            </StackPanel>
        </WrapPanel>
        <WrapPanel Orientation="Vertical" HorizontalAlignment="Left" Width="355" Grid.Row="1" Margin="1103,13,0,22" RenderTransformOrigin="0.5,0.5">
            <WrapPanel.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform AngleY="0.11" AngleX="0.007"/>
                    <RotateTransform/>
                    <TranslateTransform Y="0.498" X="0.003"/>
                </TransformGroup>
            </WrapPanel.RenderTransform>
            <StackPanel  Orientation="Vertical" Width="312" Height="70">

                <TextBlock Text="Фильтрация по скидке" TextAlignment="Left"
       Width="306" FontSize="20" Height="25">
                    <TextBlock.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform/>
                            <SkewTransform/>
                            <RotateTransform Angle="0.017"/>
                            <TranslateTransform/>
                        </TransformGroup>
                    </TextBlock.RenderTransform></TextBlock>
                <ComboBox x:Name="ComboType" SelectionChanged="ComboType_SelectionChanged"
      FontSize="15" Width="295" Height="23" RenderTransformOrigin="1.199,0.548" HorizontalAlignment="Left" >

                    <TextBlock><Run Text="Все диапазоны"/></TextBlock>
                    <TextBlock><Run Text="от 0 до 9,99%"/></TextBlock>
                    <TextBlock><Run Text="от 10 до 14,99%"/></TextBlock>
                    <TextBlock><Run Text="от 15 и более"/></TextBlock>
                </ComboBox>
            </StackPanel>
        </WrapPanel>

        <StackPanel Orientation="Vertical" HorizontalAlignment="Left" Margin="630,17,0,22" Grid.Row="1" Width="300"  >
            <RadioButton Content="По возврастанию стоимости" GroupName="Sort" Width="304" FontSize="20" Checked="RButtonUp_Checked" x:Name="RButtonUp" Height="25" />
            <RadioButton Content="По убыванию стоимости" GroupName="Sort" Width="304" FontSize="20" Checked="RButtonDown_Checked" x:Name="RButtonDown" Height="33"  />
        </StackPanel>
        <ListView Name="ProductListView" Grid.Row="2" SelectionChanged="ProductListView_SelectionChanged" Margin="0,10,0,0" >
            <ListView.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Добавить к заказу" Click="AddToOrderMenuItem_Click"></MenuItem>
                </ContextMenu>
            </ListView.ContextMenu>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition></ColumnDefinition>
                            <ColumnDefinition Width="800"></ColumnDefinition>
                            <ColumnDefinition></ColumnDefinition>

                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="50"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Image Width="200" Grid.Column="0" Grid.RowSpan="400" Stretch="UniformToFill" HorizontalAlignment="Center">
                            <Image.Source>
                                <Binding Path="ProductPhotoPath">
                                    <Binding.TargetNullValue>
                                        <ImageSource>
                                            /res/picture.png
                                        </ImageSource>
                                    </Binding.TargetNullValue>
                                </Binding>
                            </Image.Source>
                        </Image>
                        <TextBlock Text="{Binding ProductName}" Grid.Column="1" Grid.Row="0" HorizontalAlignment="Left" FontSize="20" TextWrapping="Wrap"></TextBlock>
                        <TextBlock Text="{Binding ProductDescription}"  Grid.Column="1" Grid.Row="1" HorizontalAlignment="Left" FontSize="20"></TextBlock>
                        <TextBlock Text="{Binding ProductManufacturer}" Grid.Column="1" Grid.Row="2" HorizontalAlignment="Left" FontSize="20"></TextBlock>
                        <TextBlock Text="{Binding ProductCost, StringFormat={}{0:0} рублей}" Grid.Column="1" Grid.Row="3" HorizontalAlignment="Left" FontSize="16"></TextBlock>
                        <TextBlock Text="{Binding ProductDiscountAmount, StringFormat={}{0} % }" Grid.Column="2" Grid.Row="1" HorizontalAlignment="Right" FontSize="25"></TextBlock>
                        <TextBlock Text="Скидка" Grid.Column="2" Grid.Row="0" HorizontalAlignment="Right" FontSize="20"></TextBlock>

                    </Grid>

                </DataTemplate>


            </ListView.ItemTemplate>

        </ListView>
        <TextBlock x:Name="Status" 
               VerticalAlignment="Center"
               HorizontalAlignment="Left" 
               Margin="9,0,0,0" 
               FontSize="20" 
               Width="159" Grid.Row="1" Height="26">
            <TextBlock.RenderTransform>
                <TransformGroup>
                    <ScaleTransform ScaleX="-1" ScaleY="-1"/>
                    <SkewTransform/>
                    <RotateTransform Angle="-180.164"/>
                    <TranslateTransform/>
                </TransformGroup>
            </TextBlock.RenderTransform>
        </TextBlock>
        <Button x:Name="ViewOrderBtn" Content="Корзина" Width="NaN" Height="40" Margin="1254,3,82,7" Visibility="Collapsed" Click="ViewOrderBtn_Click"></Button>

    </Grid>
</Page>
